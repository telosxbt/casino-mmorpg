# ── Frontend environment (Railway service: frontend) ──
# Vite exposes only VITE_-prefixed vars to the client. NEVER put secrets here.

VITE_API_URL=https://your-backend.up.railway.app
VITE_SOCKET_URL=https://your-backend.up.railway.app

# Public Solana config (safe to expose)
VITE_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
VITE_TOKEN_MINT=REPLACE_ME_spl_mint_address
VITE_BANKROLL_WALLET=REPLACE_ME_bankroll_pubkey
