# ── Backend environment (Railway service: backend) ──
# Copy to Railway variables. NEVER commit real values.

# Postgres + Redis: on Railway, reference the managed plugins:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}
#   REDIS_URL=${{Redis.REDIS_URL}}
DATABASE_URL=postgresql://user:pass@localhost:5432/casino
REDIS_URL=redis://localhost:6379

# HTTP
PORT=3000
CORS_ORIGINS=https://your-frontend.up.railway.app

# Auth — generate strong random secrets (e.g. `openssl rand -base64 48`)
JWT_ACCESS_SECRET=REPLACE_ME_access
JWT_REFRESH_SECRET=REPLACE_ME_refresh

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
TOKEN_MINT=REPLACE_ME_spl_mint_address
BANKROLL_WALLET=REPLACE_ME_bankroll_pubkey
# Bankroll signer secret key (base58). Railway secret ONLY — hot wallet.
# Keep minimal float here; never log it; rotate on any suspicion.
BANKROLL_PRIVATE_KEY=REPLACE_ME_bankroll_secret_key_base58
